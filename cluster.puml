@startuml
!include https://raw.githubusercontent.com/bschwarz/puml-themes/master/themes/cerulean/puml-theme-cerulean.puml
'https://plantuml.com/ru/sitemap-language-specification

skinparam defaultFontSize 16
agent USER

node "Kubernetes cluster" {
    package "Not Auth" {
        [Front]
        [USER] --> [Front] : Логируется
    }

    package "Auth depended on MS" {
        [Personal Cabinet (Pinger) MS]
        [Order MS]
        [Payment MS]
    }

    package "Queue" {
        [Kafka]
        [Order MS] -> [Kafka] : Заказ создан
        [Payment MS] -> [Kafka] : Успешная оплата
    }

    package "Inside cluster MS" {
        [Notification MS]
        [Notification MS] --> [Kafka]
        [Kafka] --> [Notification MS]
    }
    note top
     Сервисы не
     требующие
     авторизация и
     не смотрящие
     наружу
    end note

    package "Api Gateway" {
        [Nginx Ingress Controller]
        [Front] -> [Nginx Ingress Controller]
        [Nginx Ingress Controller] --> [Auth depended on MS] : Успешная авторизация
        [Nginx Ingress Controller] -> [Front]
        [Personal Cabinet (Pinger) MS] -> [Nginx Ingress Controller]
        [Order MS] -> [Nginx Ingress Controller]
    }
}

node "Remote services" {
    package "Payment" {
        [acquiring]
        [Order MS] --> [acquiring]
        [acquiring] -> [Payment MS] : Callback
    }
}
@enduml
